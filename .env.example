# ─── API Keys ────────────────────────────────────────────────────────
# Infomaniak: motor-drota + persona-simulator + planejador (default Kimi K2.5)
INFOMANIAK_API_KEY=...
INFOMANIAK_BASE_URL=https://api.infomaniak.com/2/ai/108102/openai/v1

# Anthropic: opcional. Só necessário se LLM_PROVIDER=anthropic ou per-callsite override.
# Default motor#21+: tudo via Infomaniak, zero Anthropic dependency.
ANTHROPIC_API_KEY=sk-ant-...

# ─── LLM Provider Routing (motor#21 + sts#12) ────────────────────────
# Defaults Kimi-first em todos callsites. Override per-step abaixo ou
# via LLM_PROVIDER global. Ver shared/src/llm-router.ts.

# LLM_PROVIDER=infomaniak  # global override

PLANEJADOR_PROVIDER=infomaniak
PLANEJADOR_MODEL=moonshotai/Kimi-K2.5

DROTA_PROVIDER=infomaniak
DROTA_MODEL=moonshotai/Kimi-K2.5

# Persona-sim recomendado: mistral3 (não-reasoning, ~5s/call) em vez de Kimi.
# Análise smoke-3d (motor#23) mostrou Kimi com 25s+ latência + truncation risk.
# Persona simulation exige fidelidade > reasoning profundo.
PERSONA_SIM_PROVIDER=infomaniak
PERSONA_SIM_MODEL=mistral3

HAIKU_TRIAGE_PROVIDER=infomaniak
HAIKU_TRIAGE_MODEL=mistral3

HAIKU_BULLYING_PROVIDER=infomaniak
HAIKU_BULLYING_MODEL=mistral3

# ─── LLM Timeouts (motor#20 + sts#11) ────────────────────────────────
ASC_LLM_TIMEOUT_PLANEJADOR=180
ASC_LLM_TIMEOUT_DROTA=240
ASC_LLM_TIMEOUT_PERSONA_SIM=180
ASC_LLM_TIMEOUT_HAIKU_TRIAGE=30
ASC_LLM_TIMEOUT_HAIKU_BULLYING=30

# ASC_LLM_MAX_RETRIES=2

# ─── max_tokens overrides (motor#21 router heuristic) ────────────────
# Heurística default: reasoning model = 4096, non-reasoning = 2048.
# Bumps estabelecidos em smoke-3d analysis pra evitar content truncation.
DROTA_MAX_TOKENS=8192
PERSONA_SIM_MAX_TOKENS=8192
PLANEJADOR_MAX_TOKENS=4096

# ─── Scenario per-event timeout (sts#11) ─────────────────────────────
# Real-LLM com Kimi: solo 5 turns × ~60-120s ≈ 300-600s.
# Joint = 2 solos sequenciais ≈ 600-1200s (débito sts#8 → b).
ASC_EVENT_TIMEOUT_SECONDS=600

# ─── Debug Mode (motor#19 + sts#10) ──────────────────────────────────
ASC_DEBUG_MODE=true
# ASC_DEBUG_RUN_ID=                # auto-gen se omitido
# ASC_DEBUG_DIR=./logs/debug       # default
# LLM_THINKING_BUDGET_TOKENS=1024  # Anthropic extended thinking

# ─── Mock LLM (sts harness rapid testing) ────────────────────────────
# USE_MOCK_LLM=true                # bypassa LLM real, retorna mocks fixos

# ─── Motor path (sts→motor child spawn) ──────────────────────────────
MOTOR_PATH=/home/alexa/ascendimacy-motor
